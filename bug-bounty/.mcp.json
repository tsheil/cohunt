{
  "mcpServers": {
    "shodan": {
      "command": "uvx",
      "args": ["mcp-shodan"],
      "env": {
        "SHODAN_API_KEY": ""
      },
      "disabled": true
    },
    "censys": {
      "command": "uvx",
      "args": ["mcp-censys"],
      "env": {
        "CENSYS_API_ID": "",
        "CENSYS_API_SECRET": ""
      },
      "disabled": true
    },
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": ""
      },
      "disabled": true
    },
    "bug-bounty-platforms": {
      "command": "npx",
      "args": ["-y", "bug-bounty-mcp"],
      "env": {
        "HACKERONE_API_TOKEN": "",
        "BUGCROWD_API_TOKEN": ""
      },
      "disabled": true
    },
    "snyk": {
      "command": "npx",
      "args": ["-y", "@snyk/mcp-server"],
      "env": {
        "SNYK_TOKEN": ""
      },
      "disabled": true
    },
    "semgrep": {
      "command": "npx",
      "args": ["-y", "@semgrep/mcp"],
      "env": {
        "SEMGREP_APP_TOKEN": ""
      },
      "disabled": true
    },
    "burp-suite": {
      "command": "npx",
      "args": ["-y", "burp-suite-mcp"],
      "env": {
        "BURP_API_URL": "http://localhost:1337"
      },
      "disabled": true
    },
    "kali-linux": {
      "command": "uvx",
      "args": ["kali-mcp"],
      "env": {},
      "disabled": true
    }
  }
}
